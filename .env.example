BEDROCK_AWS_REGION="us-east-1"
BEDROCK_AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
BEDROCK_AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
# Optional for temporary AWS credentials
# BEDROCK_AWS_SESSION_TOKEN="YOUR_AWS_SESSION_TOKEN"
# Nova 2 Lite on Bedrock on-demand should use the inference profile ID, not the raw model ID.
BEDROCK_MODEL_ID="us.amazon.nova-2-lite-v1:0"

LANGCHAIN_CALLBACKS_BACKGROUND=false
LANGGRAPH_API_URL="http://localhost:54367"
SIMIEBOT_VIDEO_BUCKET="YOUR_S3_BUCKET_FOR_SOURCE_AND_RENDERED_VIDEOS"
# Optional prefix inside the bucket for staged assets and renders.
# SIMIEBOT_VIDEO_PREFIX="simiebot/creator"
# Optional path to the ffmpeg binary if it is not on PATH.
# FFMPEG_PATH="/usr/bin/ffmpeg"
# Optional YouTube category id. Defaults to "22" (People & Blogs).
# SIMIEBOT_YOUTUBE_CATEGORY_ID="22"

# Optional web search
# SERPAPI_API_KEY="YOUR_SERPAPI_KEY"

APP_BASE_URL="http://localhost:3000"
AUTH0_SECRET="use [openssl rand -hex 32] to generate a 32 byte value"
AUTH0_DOMAIN="dev-example.us.auth0.com"
AUTH0_CLIENT_ID="YOUR_REGULAR_WEB_APP_CLIENT_ID"
AUTH0_CLIENT_SECRET="YOUR_REGULAR_WEB_APP_CLIENT_SECRET"
# This should be your custom API audience for the app/LangGraph flow, not the Auth0 Management API audience.
AUTH0_AUDIENCE="https://simiebot.local"
AUTH0_SCOPE="openid profile email offline_access"
# These must come from the Custom API Client used for Token Vault exchange, not the regular web app.
AUTH0_CUSTOM_API_CLIENT_ID="YOUR_CUSTOM_API_CLIENT_ID"
AUTH0_CUSTOM_API_CLIENT_SECRET="YOUR_CUSTOM_API_CLIENT_SECRET"

# Supabase Persistence
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Optional tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY="YOUR_LANGSMITH_API_KEY"
